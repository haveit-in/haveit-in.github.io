# Copy to `.env.local` and fill in values. Never commit real secrets.

# Required: JWT signing (min ~16 chars; use a long random string in production)
SECRET_KEY=

# Optional: during SECRET_KEY rotation, keep the old key here until tokens expire
# SECRET_KEY_PREVIOUS=

# environment=development | staging | production
# ENVIRONMENT=development

# Local-only: set true to run SQLAlchemy create_all on startup (never in production)
# CREATE_TABLES_ON_STARTUP=false

# Comma-separated browser origins for CORS (override per environment)
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# JWT lifetimes
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=14

# Payments (Razorpay)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# CI / tests: skip Firebase Admin init when no credentials are present
# SKIP_FIREBASE_INIT=true
